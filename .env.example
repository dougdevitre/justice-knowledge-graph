# -------------------------------------------------------
# Justice Knowledge Graph — Environment Configuration
# Copy this file to .env and fill in your values.
# -------------------------------------------------------

# Application environment: development | staging | production
NODE_ENV=development

# REST API server port
PORT=3000

# --- Neo4j Graph Database ---

# Bolt protocol connection URI
NEO4J_URI=bolt://localhost:7687

# Neo4j authentication username
NEO4J_USER=neo4j

# Neo4j authentication password
NEO4J_PASSWORD=your-password

# --- Elasticsearch (full-text search) ---

# Elasticsearch cluster URL
ELASTICSEARCH_URL=http://localhost:9200

# --- API Authentication ---

# API key required for GraphQL and REST endpoints
API_KEY=your-api-key

# --- Ingestion Settings ---

# Number of records to process per batch during ingestion
INGESTION_BATCH_SIZE=100

# --- Cache ---

# Cache time-to-live in seconds for query results
CACHE_TTL_SECONDS=3600
